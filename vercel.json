{
  "version": 2,
  "name": "hospora-frontend",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://your-backend-url.onrender.com/api/$1",
      "headers": {
        "x-forwarded-host": "$host"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    },
    {
      "src": "/((?!.*\\.).*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
